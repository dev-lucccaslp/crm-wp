# ============== Infra (docker-compose) ==============
POSTGRES_USER=crmwp
POSTGRES_PASSWORD=crmwp
POSTGRES_DB=crmwp
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

EVOLUTION_PORT=8080
EVOLUTION_API_KEY=change-me-evolution-key

# ============== Backend ==============
NODE_ENV=development
BACKEND_PORT=3333

DATABASE_URL=postgresql://crmwp:crmwp@localhost:5432/crmwp?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=crmwp-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Evolution API
EVOLUTION_BASE_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-evolution-key
EVOLUTION_WEBHOOK_TOKEN=change-me-webhook-token

# CORS
CORS_ORIGIN=http://localhost:5173

# Stripe (Fase 6)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
BILLING_SUCCESS_URL=http://localhost:5173/app/settings/billing?success=1
BILLING_CANCEL_URL=http://localhost:5173/app/settings/billing?canceled=1

# Hardening (Fase 8) — chave para AES-256-GCM (>=32 chars); em dev, se ausente, deriva de JWT_ACCESS_SECRET com warning
ENCRYPTION_KEY=
# OpenTelemetry (opcional) — quando true, initTracing() carrega SDK real (stub no-op por padrão)
OTEL_ENABLED=false

# ============== Frontend ==============
VITE_API_URL=http://localhost:3333
VITE_SOCKET_URL=http://localhost:3333
